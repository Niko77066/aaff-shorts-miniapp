/**
 * AAFF AI Video Rankings - Global Styles
 * Design System: Clean Minimal Dark — editorial, professional typography
 */

page {
  /* ─── Color System (Dark Theme) ─── */
  --color-bg: #0a0510;
  --color-surface: #1a1a1e;
  --color-surface-elevated: #242428;
  --color-surface-alt: rgba(255, 255, 255, 0.04);
  --color-surface-hover: rgba(255, 255, 255, 0.06);
  --color-border: rgba(255, 255, 255, 0.06);
  --color-border-strong: rgba(255, 255, 255, 0.10);

  /* Text */
  --color-text-primary: #FFFFFF;
  --color-text-secondary: #a1a1aa;
  --color-text-tertiary: #52525b;
  --color-text-inverse: #0a0510;

  /* Accent */
  --color-accent: #60a5fa;
  --color-accent-dark: #3b82f6;
  --color-accent-light: rgba(96, 165, 250, 0.10);
  --color-accent-gradient: linear-gradient(135deg, #60a5fa 0%, #818cf8 100%);

  /* Secondary accent — orange */
  --color-secondary: #f97316;
  --color-secondary-light: rgba(249, 115, 22, 0.08);

  /* Status */
  --color-gold: #fbbf24;
  --color-gold-gradient: linear-gradient(180deg, #FDE68A 0%, #F59E0B 50%, #D97706 100%);
  --color-gold-light: rgba(251, 191, 36, 0.08);
  --color-silver: #a1a1aa;
  --color-silver-gradient: linear-gradient(180deg, #F4F4F5 0%, #A1A1AA 50%, #71717A 100%);
  --color-bronze: #ea580c;
  --color-bronze-gradient: linear-gradient(180deg, #FDBA74 0%, #EA580C 50%, #9A3412 100%);
  --color-success: #34d399;
  --color-success-light: rgba(52, 211, 153, 0.08);
  --color-warning: #fbbf24;
  --color-danger: #f43f5e;
  --color-danger-light: rgba(244, 63, 94, 0.08);

  --color-tag-bg: rgba(255, 255, 255, 0.06);

  /* ─── Shadows (dark theme) ─── */
  --shadow-xs: 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
  --shadow-xl: 0 16rpx 48rpx rgba(0, 0, 0, 0.6);
  --shadow-accent: 0 8rpx 24rpx rgba(96, 165, 250, 0.12);
  --shadow-gold: 0 4rpx 16rpx rgba(251, 191, 36, 0.2);

  /* ─── Radius ─── */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-2xl: 48rpx;
  --radius-full: 999rpx;

  /* ─── Spacing ─── */
  --sp-2: 4rpx;
  --sp-4: 8rpx;
  --sp-6: 12rpx;
  --sp-8: 16rpx;
  --sp-12: 24rpx;
  --sp-16: 32rpx;
  --sp-20: 40rpx;
  --sp-24: 48rpx;
  --sp-32: 64rpx;

  /* ─── Typography ─── */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-2xl: 48rpx;
  --font-3xl: 60rpx;

  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: var(--font-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  -webkit-font-smoothing: antialiased;
}

/* ─── Reset ─── */
view, text, image, scroll-view, swiper {
  box-sizing: border-box;
}

/* ─── Flex Utilities ─── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }
.flex-1 { flex: 1; min-width: 0; }
.flex-shrink-0 { flex-shrink: 0; }
.gap-8 { gap: 16rpx; }
.gap-12 { gap: 24rpx; }

.text-center { text-align: center; }
.text-right { text-align: right; }
.overflow-hidden { overflow: hidden; }
.relative { position: relative; }
.absolute { position: absolute; }
.w-full { width: 100%; }

/* ─── Text Truncation ─── */
.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.line-clamp-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ─── Glass Panel (used sparingly) ─── */
.glass-panel {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

/* ─── Card System (Dark) ─── */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  overflow: hidden;
}
.card-elevated {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--color-border);
  overflow: hidden;
}

/* ─── Badge ─── */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 600;
}
.badge-accent {
  background: var(--color-accent-light);
  color: var(--color-accent);
}

/* ─── Text Gradients ─── */
.text-gradient {
  background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.text-gradient-gold {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ─── Animations ─── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(32rpx); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.animate-in {
  animation: fadeInUp 0.45s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}
.animate-scale {
  animation: scaleIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}
