/**
 * AAFF AI Video Rankings - Global Styles
 * Design System: Modern Dashboard — inspired by Dribbble management dashboards
 * Palette: Cool gray base, indigo-violet accent gradient, soft layered shadows
 */

page {
  /* ─── Color System ─── */
  --color-bg: #F4F5FA;
  --color-surface: #FFFFFF;
  --color-surface-elevated: #FFFFFF;
  --color-surface-alt: #F0F1F8;
  --color-surface-hover: #F7F7FC;
  --color-border: rgba(0, 0, 0, 0.05);
  --color-border-strong: rgba(0, 0, 0, 0.08);

  /* Text */
  --color-text-primary: #1E1F2B;
  --color-text-secondary: #6E7191;
  --color-text-tertiary: #A0A3BD;
  --color-text-inverse: #FFFFFF;

  /* Accent — indigo to violet gradient */
  --color-accent: #6C5CE7;
  --color-accent-dark: #5A4BD1;
  --color-accent-light: #F0EEFF;
  --color-accent-gradient: linear-gradient(135deg, #6C5CE7 0%, #A17FE0 100%);

  /* Secondary accent — warm coral */
  --color-secondary: #FF6B6B;
  --color-secondary-light: #FFF0F0;

  /* Status */
  --color-gold: #FFB020;
  --color-gold-light: #FFF8E8;
  --color-silver: #A0A3BD;
  --color-bronze: #CD7F32;
  --color-success: #00C48C;
  --color-success-light: #E6FAF3;
  --color-warning: #FFB020;
  --color-danger: #FF6B6B;

  --color-tag-bg: #F0F1F8;

  /* ─── Shadows — layered for depth ─── */
  --shadow-xs: 0 1rpx 3rpx rgba(0, 0, 0, 0.02);
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04), 0 1rpx 2rpx rgba(0, 0, 0, 0.02);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06), 0 2rpx 4rpx rgba(0, 0, 0, 0.02);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  --shadow-xl: 0 16rpx 48rpx rgba(0, 0, 0, 0.10), 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  --shadow-accent: 0 8rpx 24rpx rgba(108, 92, 231, 0.25);

  /* ─── Radius — generous for modern feel ─── */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-2xl: 48rpx;
  --radius-full: 999rpx;

  /* ─── Spacing ─── */
  --sp-2: 4rpx;
  --sp-4: 8rpx;
  --sp-6: 12rpx;
  --sp-8: 16rpx;
  --sp-12: 24rpx;
  --sp-16: 32rpx;
  --sp-20: 40rpx;
  --sp-24: 48rpx;
  --sp-32: 64rpx;

  /* ─── Typography ─── */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-2xl: 48rpx;
  --font-3xl: 60rpx;

  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: var(--font-base);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  -webkit-font-smoothing: antialiased;
}

/* ─── Reset ─── */
view, text, image, scroll-view, swiper {
  box-sizing: border-box;
}

/* ─── Flex Utilities ─── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }
.flex-1 { flex: 1; min-width: 0; }
.flex-shrink-0 { flex-shrink: 0; }
.gap-8 { gap: 16rpx; }
.gap-12 { gap: 24rpx; }

.text-center { text-align: center; }
.text-right { text-align: right; }
.overflow-hidden { overflow: hidden; }
.relative { position: relative; }
.absolute { position: absolute; }
.w-full { width: 100%; }

/* ─── Text Truncation ─── */
.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.line-clamp-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ─── Card System ─── */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--color-border);
  overflow: hidden;
}
.card-elevated {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  border: none;
  overflow: hidden;
}

/* ─── Badge ─── */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 600;
}
.badge-accent {
  background: var(--color-accent-light);
  color: var(--color-accent);
}

/* ─── Animations ─── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(32rpx); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.animate-in {
  animation: fadeInUp 0.45s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}
.animate-scale {
  animation: scaleIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}
