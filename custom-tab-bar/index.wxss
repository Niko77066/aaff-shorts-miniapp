/* Custom Tab Bar — Dark Glass */
.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(0, 0, 0, 0.60);
  backdrop-filter: blur(60px);
  -webkit-backdrop-filter: blur(60px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  position: relative;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 10rpx 0;
}

.tab-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
  transition: transform 0.3s;
}

.tab-item.active .tab-icon-wrap {
  transform: scale(1.1);
}

/* Chart/BarChart2 Icon */
.icon-svg {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  width: 44rpx;
  height: 44rpx;
}

.chart-bar {
  width: 10rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #71717a;
  transition: background 0.3s;
}
.bar-1 { height: 20rpx; }
.bar-2 { height: 32rpx; }
.bar-3 { height: 26rpx; }
.icon-active .chart-bar { background: #60a5fa; }

/* User Icon */
.user-head {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 3rpx solid #71717a;
  position: absolute;
  top: 6rpx;
  transition: border-color 0.3s;
}
.user-body {
  width: 28rpx;
  height: 14rpx;
  border-radius: 14rpx 14rpx 0 0;
  border: 3rpx solid #71717a;
  border-bottom: none;
  position: absolute;
  bottom: 6rpx;
  transition: border-color 0.3s;
}
.icon-active .user-head { border-color: #60a5fa; }
.icon-active .user-body { border-color: #60a5fa; }

/* Icon container for user icon needs relative positioning */
.tab-item:last-child .icon-svg {
  position: relative;
}

.tab-label {
  font-size: 20rpx;
  color: #71717a;
  font-weight: 500;
  transition: color 0.3s;
}
.label-active {
  color: #60a5fa;
}
