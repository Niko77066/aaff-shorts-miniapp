/* Custom Tab Bar — Floating Pill (Reference Design) */

.tab-bar-wrap {
  position: fixed;
  bottom: 32rpx;
  left: 0;
  right: 0;
  z-index: 999;
  display: flex;
  justify-content: center;
  pointer-events: none;
  padding: 0 60rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-pill {
  display: flex;
  align-items: center;
  gap: 48rpx;
  background: rgba(28, 28, 30, 0.80);
  -webkit-backdrop-filter: blur(40px);
  backdrop-filter: blur(40px);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 999rpx;
  padding: 14rpx 48rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.tab-pill-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 80rpx;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}

.tab-pill-item-icon {
  font-size: 40rpx;
  opacity: 0.4;
  transition: opacity 0.3s, transform 0.3s;
}

.tab-pill-item-icon-active {
  opacity: 1;
  transform: scale(1.1);
}

.tab-pill-item-label {
  font-size: 18rpx;
  color: #71717a;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: color 0.3s;
}

.tab-pill-item-label-active {
  color: #FFFFFF;
  font-weight: 600;
  text-shadow: 0 0 16rpx rgba(255, 255, 255, 0.5);
}
