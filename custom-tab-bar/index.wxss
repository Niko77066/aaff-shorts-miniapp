/* Custom Tab Bar */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  background: rgba(10, 15, 20, 0.92);
  backdrop-filter: blur(32rpx);
  -webkit-backdrop-filter: blur(32rpx);
  border-top: 1rpx solid rgba(48, 54, 61, 0.3);
  padding-top: 16rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.tab-bar-icon-text {
  font-size: 40rpx;
  color: #484F58;
  line-height: 1;
}

.tab-bar-label {
  font-size: 20rpx;
  color: #484F58;
  font-weight: 500;
}

.tab-bar-item.active .tab-bar-icon-text {
  color: #00A896;
}

.tab-bar-item.active .tab-bar-label {
  color: #00A896;
}
