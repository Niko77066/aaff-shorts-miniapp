<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="{{index}}"
  >
    <text class="tab-bar-icon-text">{{item.iconText}}</text>
    <text class="tab-bar-label">{{item.text}}</text>
  </view>
</view>
