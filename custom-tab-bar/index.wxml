<view class="tab-bar-wrap">
  <view class="tab-bar-pill">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-pill-item {{selected === index ? 'tab-pill-item-active' : ''}}"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      <text class="tab-pill-item-icon {{selected === index ? 'tab-pill-item-icon-active' : ''}}">{{selected === index ? item.activeIcon : item.icon}}</text>
      <text class="tab-pill-item-label {{selected === index ? 'tab-pill-item-label-active' : ''}}">{{item.text}}</text>
    </view>
  </view>
</view>
