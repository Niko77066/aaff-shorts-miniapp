<!-- Profile Page — Clean Minimal -->
<view class="page-profile">
  <!-- Header -->
  <view class="profile-header" style="padding-top: {{statusBarHeight + 20}}px;">
    <!-- User Info -->
    <view class="user-section flex flex-col items-center">
      <view class="avatar-wrap" bindtap="onAvatarTap">
        <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" wx:if="{{userInfo.avatar}}"></image>
        <view class="user-avatar-placeholder" wx:else>
          <text class="avatar-letter">U</text>
        </view>
      </view>
      <text class="user-name">{{userInfo.name || '点击登录'}}</text>
      <text class="user-desc">{{userInfo.desc || 'AI视频爱好者'}}</text>
    </view>

    <!-- Stats Row -->
    <view class="profile-stats flex items-center justify-center">
      <view class="profile-stat flex flex-col items-center">
        <text class="profile-stat-num">{{stats.watched}}</text>
        <text class="profile-stat-label">已观看</text>
      </view>
      <view class="profile-stat-divider"></view>
      <view class="profile-stat flex flex-col items-center">
        <text class="profile-stat-num">{{stats.liked}}</text>
        <text class="profile-stat-label">已点赞</text>
      </view>
      <view class="profile-stat-divider"></view>
      <view class="profile-stat flex flex-col items-center">
        <text class="profile-stat-num">{{stats.collected}}</text>
        <text class="profile-stat-label">已收藏</text>
      </view>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item flex items-center" bindtap="goTo" data-page="history">
        <text class="menu-icon-text">⚙</text>
        <text class="menu-item-text flex-1">观看历史</text>
        <text class="menu-arrow-text">›</text>
      </view>
      <view class="menu-item flex items-center" bindtap="goTo" data-page="favorites">
        <text class="menu-icon-text">☆</text>
        <text class="menu-item-text flex-1">我的收藏</text>
        <text class="menu-arrow-text">›</text>
      </view>
      <view class="menu-item flex items-center" bindtap="goTo" data-page="likes">
        <text class="menu-icon-text">♡</text>
        <text class="menu-item-text flex-1">我的点赞</text>
        <text class="menu-arrow-text">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item flex items-center" bindtap="goTo" data-page="submit">
        <text class="menu-icon-text">◉</text>
        <text class="menu-item-text flex-1">提交作品</text>
        <view class="menu-badge">NEW</view>
        <text class="menu-arrow-text">›</text>
      </view>
      <view class="menu-item flex items-center" bindtap="goTo" data-page="about">
        <text class="menu-icon-text">ⓘ</text>
        <text class="menu-item-text flex-1">关于AAFF</text>
        <text class="menu-arrow-text">›</text>
      </view>
      <view class="menu-item flex items-center" bindtap="goTo" data-page="feedback">
        <text class="menu-icon-text">↗</text>
        <text class="menu-item-text flex-1">意见反馈</text>
        <text class="menu-arrow-text">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item flex items-center" bindtap="goTo" data-page="settings">
        <text class="menu-icon-text">⏻</text>
        <text class="menu-item-text flex-1">设置</text>
        <text class="menu-arrow-text">›</text>
      </view>
    </view>
  </view>

  <!-- Version -->
  <view class="version-text text-center">
    <text class="version">AAFF AI视频榜 v1.0.0</text>
  </view>
</view>
