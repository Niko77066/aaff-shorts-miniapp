/* ════════════════════════════════════════
   Profile Page — Dark Cyberpunk Theme
   ════════════════════════════════════════ */

.page-profile {
  min-height: 100vh;
  background: var(--color-bg);
}

/* Header */
.profile-header {
  position: relative;
  padding-bottom: 48rpx;
  background: var(--color-surface);
  border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
  border-bottom: 2rpx solid var(--color-border);
}
.profile-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 340rpx;
  background: linear-gradient(135deg, #581c87 0%, #7c3aed 50%, #4c1d95 100%);
  border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
}

/* User Section */
.user-section {
  position: relative;
  z-index: 1;
  padding: 48rpx 0 0;
}
.avatar-wrap {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 8rpx solid var(--color-surface);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  margin-bottom: 24rpx;
}
.user-avatar { width: 100%; height: 100%; }
.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #60a5fa, #818cf8);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-letter {
  font-size: var(--font-3xl);
  font-weight: 900;
  color: #FFFFFF;
}
.user-name {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}
.user-desc {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* Stats */
.profile-stats {
  margin-top: 36rpx;
  padding: 0 60rpx;
}
.profile-stat { flex: 1; }
.profile-stat-num {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  line-height: 1;
}
.profile-stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  margin-top: 10rpx;
  font-weight: 500;
}
.profile-stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--color-border);
}

/* Menu */
.menu-section {
  padding: 24rpx;
}
.menu-group {
  margin-bottom: 20rpx;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
}
.menu-item {
  padding: 28rpx 28rpx;
  border-bottom: 2rpx solid var(--color-border);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.05);
}
.menu-icon-emoji {
  font-size: 30rpx;
}
.menu-item-text {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
}
.menu-badge {
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: linear-gradient(135deg, #60a5fa, #818cf8);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  margin-right: 14rpx;
}
.menu-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-tertiary);
  font-weight: 300;
}

/* Version */
.version-text {
  padding: 48rpx 0 100rpx;
}
.version {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  font-weight: 500;
}
