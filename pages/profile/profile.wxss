/* ════════════════════════════════════════
   Profile Page — Clean Minimal
   ════════════════════════════════════════ */

.page-profile {
  min-height: 100vh;
  background: var(--color-bg);
}

/* Header */
.profile-header {
  position: relative;
  padding-bottom: 40rpx;
  background: var(--color-surface);
  border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
  border-bottom: 1px solid var(--color-border);
}

/* User Section */
.user-section {
  position: relative;
  z-index: 1;
  padding: 48rpx 0 0;
}
.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.10);
  overflow: hidden;
  margin-bottom: 20rpx;
}
.user-avatar {
  width: 100%;
  height: 100%;
}
.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-letter {
  font-size: var(--font-2xl);
  font-weight: 800;
  color: rgba(255, 255, 255, 0.4);
}
.user-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}
.user-desc {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* Stats */
.profile-stats {
  margin-top: 32rpx;
  padding: 0 60rpx;
}
.profile-stat {
  flex: 1;
}
.profile-stat-num {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  line-height: 1;
}
.profile-stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
  font-weight: 500;
}
.profile-stat-divider {
  width: 1px;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* Menu */
.menu-section {
  padding: 24rpx;
}
.menu-group {
  margin-bottom: 16rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--color-surface);
  border: 1px solid rgba(255, 255, 255, 0.06);
}
.menu-item {
  padding: 28rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  color: var(--color-text-secondary);
}
.menu-item-text {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-text-primary);
}
.menu-badge {
  font-size: 18rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: var(--color-accent);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-right: 12rpx;
}
.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
}

/* Version */
.version-text {
  padding: 48rpx 0 200rpx;
}
.version {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  font-weight: 500;
}
