<!--
  AAFF AI Video Rankings - Index Page
  Reference Design: AI Studio (floating pill nav, hero banner, podium)
-->
<view class="page">
  <!-- Background gradient orbs -->
  <view class="bg-gradient">
    <view class="bg-orb bg-orb-purple"></view>
    <view class="bg-orb bg-orb-rose"></view>
    <view class="bg-orb bg-orb-amber"></view>
    <view class="bg-orb bg-orb-blue"></view>
  </view>

  <!-- Header (sticky) -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-fade"></view>
    <view class="nav-bar-inner">
      <!-- Left: Logo + Brand -->
      <view class="nav-left flex items-center">
        <view class="nav-logo-mark">A</view>
        <text class="nav-brand">AAFF</text>
      </view>
      <!-- Right: Search + Bell -->
      <view class="nav-right flex items-center">
        <view class="nav-icon-btn" bindtap="">
          <text class="nav-icon-emoji">\uD83D\uDD0D</text>
        </view>
        <view class="nav-icon-btn" bindtap="">
          <text class="nav-icon-emoji">\uD83D\uDD14</text>
        </view>
      </view>
    </view>

    <!-- Pill Tabs -->
    <view class="tab-pills flex">
      <view
        class="tab-pill {{activeMainTab === 0 ? 'tab-pill-active' : 'tab-pill-inactive'}}"
        bindtap="switchMainTab"
        data-index="0"
      >
        <text class="tab-pill-icon">\uD83C\uDFAC</text>
        <text class="tab-pill-label">AI 短片</text>
      </view>
      <view
        class="tab-pill {{activeMainTab === 1 ? 'tab-pill-active' : 'tab-pill-inactive'}}"
        bindtap="switchMainTab"
        data-index="1"
      >
        <text class="tab-pill-icon">\uD83C\uDFAD</text>
        <text class="tab-pill-label">AI 短剧</text>
      </view>
    </view>
  </view>

  <!-- Spacer for fixed nav -->
  <view style="height: {{navHeight + 120}}px;"></view>

  <!-- Scrollable Content -->
  <scroll-view
    class="main-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
    bindscrolltolower="onLoadMore"
  >
    <!-- Hero Banner -->
    <view class="hero-banner-section" wx:if="{{featured}}">
      <view class="hero-banner">
        <view class="hero-banner-bg" style="background: {{featured.gradient}};"></view>
        <view class="hero-banner-overlay-top"></view>
        <view class="hero-banner-overlay-bottom"></view>
        <view class="hero-banner-content">
          <view class="hero-banner-badge">
            <text class="hero-banner-badge-text">{{featured.badge}}</text>
          </view>
          <text class="hero-banner-title">{{featured.title}}</text>
          <text class="hero-banner-author">作者: {{featured.author}}</text>
          <text class="hero-banner-desc line-clamp-2">{{featured.description}}</text>
          <view class="hero-banner-btn">
            <text class="hero-banner-btn-icon">▶</text>
            <text class="hero-banner-btn-text">立即观看</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Section Title -->
    <view class="section-title flex items-center justify-between">
      <text class="section-title-text">本周排行榜</text>
      <text class="section-title-badge">TOP 10</text>
    </view>

    <!-- Podium (Top 3) -->
    <view class="podium flex items-end justify-center" wx:if="{{podiumItems.length >= 3}}">
      <!-- Rank 2 -->
      <view class="podium-item podium-item-2 flex flex-col items-center">
        <view class="podium-avatar-ring podium-ring-silver">
          <view class="podium-avatar-inner">
            <text class="podium-avatar-letter">{{podiumItems[1].author[0]}}</text>
          </view>
        </view>
        <view class="podium-name-bubble">
          <text class="podium-name">{{podiumItems[1].author}}</text>
        </view>
        <text class="podium-score podium-score-silver">{{podiumItems[1].score}}分</text>
        <view class="podium-pillar pillar-silver">
          <view class="pillar-shine"></view>
          <text class="pillar-rank">2</text>
        </view>
      </view>

      <!-- Rank 1 -->
      <view class="podium-item podium-item-1 flex flex-col items-center">
        <text class="podium-crown">\uD83D\uDC51</text>
        <view class="podium-avatar-ring podium-ring-gold">
          <view class="podium-avatar-inner">
            <text class="podium-avatar-letter">{{podiumItems[0].author[0]}}</text>
          </view>
        </view>
        <view class="podium-name-bubble">
          <text class="podium-name">{{podiumItems[0].author}}</text>
        </view>
        <text class="podium-score podium-score-gold">{{podiumItems[0].score}}分</text>
        <view class="podium-pillar pillar-gold">
          <view class="pillar-shine"></view>
          <text class="pillar-rank">1</text>
        </view>
      </view>

      <!-- Rank 3 -->
      <view class="podium-item podium-item-3 flex flex-col items-center">
        <view class="podium-avatar-ring podium-ring-bronze">
          <view class="podium-avatar-inner">
            <text class="podium-avatar-letter">{{podiumItems[2].author[0]}}</text>
          </view>
        </view>
        <view class="podium-name-bubble">
          <text class="podium-name">{{podiumItems[2].author}}</text>
        </view>
        <text class="podium-score podium-score-bronze">{{podiumItems[2].score}}分</text>
        <view class="podium-pillar pillar-bronze">
          <view class="pillar-shine"></view>
          <text class="pillar-rank">3</text>
        </view>
      </view>
    </view>

    <!-- Leaderboard Cards (all ranks) -->
    <view class="cards-section">
      <view
        class="lb-card animate-in"
        style="animation-delay: {{index * 0.06}}s;"
        wx:for="{{rankItems}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <!-- Background Gradient (CSS only, no images) -->
        <view class="lb-card-bg">
          <view class="lb-card-bg-gradient" style="background: linear-gradient(135deg, {{item.gradientFrom}}, {{item.gradientTo}});"></view>
          <view class="lb-card-bg-fade"></view>
        </view>

        <!-- Card Content -->
        <view class="lb-card-content">
          <!-- Header: Rank Badge + Title -->
          <view class="lb-header flex items-start">
            <!-- Rank Badge -->
            <view wx:if="{{item.rank <= 3}}" class="rank-badge-pennant {{item.badgeClass}}">
              <text class="pennant-top">TOP</text>
              <text class="pennant-num">{{item.rank}}</text>
            </view>
            <view wx:else class="rank-badge-simple">
              <text class="rank-badge-simple-num">{{item.rank}}</text>
            </view>

            <view class="lb-title-area flex-1">
              <text class="lb-title line-clamp-1">{{item.title}}</text>
              <text class="lb-author">{{item.author}}</text>
            </view>
          </view>

          <!-- Stats Row -->
          <view class="lb-stats flex items-center">
            <!-- Approval Badge -->
            <view class="progress-wrap flex items-center">
              <view class="approval-badge" style="border-color: {{item.approvalColor}};">
                <text class="approval-num" style="color: {{item.approvalColor}};">{{item.approval}}</text>
              </view>
              <text class="progress-label">好评率</text>
            </view>

            <view class="stats-info flex flex-col">
              <view class="stat-line flex items-center">
                <text class="stat-icon-fire">\uD83D\uDD25</text>
                <text class="stat-text-light">评分 {{item.score}}</text>
              </view>
              <view class="stat-line flex items-center">
                <text class="stat-icon-play">▶</text>
                <text class="stat-text-dim">播放 {{item.views}}</text>
              </view>
            </view>

            <!-- Tags -->
            <view class="lb-tags flex">
              <text class="lb-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
            </view>
          </view>

          <!-- Description Quote -->
          <view class="lb-quote" wx:if="{{item.description}}">
            <text class="quote-mark quote-open">"</text>
            <text class="quote-text line-clamp-2">{{item.description}}</text>
            <text class="quote-mark quote-close">"</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Load More -->
    <view class="load-more-area" wx:if="{{hasMore}}">
      <view class="pulse-dots flex justify-center items-center">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>
    </view>
    <view class="end-line" wx:else>
      <view class="end-divider"></view>
      <text class="end-text">已经到底了</text>
      <view class="end-divider"></view>
    </view>

    <!-- Safe area for floating nav -->
    <view style="height: 240rpx;"></view>
  </scroll-view>
</view>
