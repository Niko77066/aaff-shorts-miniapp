<!--
  AAFF AI Video Rankings - Index Page
  Dark Cyberpunk Theme with Podium + Leaderboard Cards
-->
<view class="page">
  <!-- Background Gradient Orbs -->
  <view class="bg-container">
    <view class="bg-orb orb-purple"></view>
    <view class="bg-orb orb-rose"></view>
    <view class="bg-orb orb-amber"></view>
    <view class="bg-orb orb-blue"></view>
  </view>

  <!-- Custom Navigation Bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-fade"></view>
    <view class="nav-bar-inner">
      <view class="nav-left flex items-center">
        <view class="logo-box">
          <text class="logo-letter">A</text>
        </view>
        <view class="flex flex-col">
          <view class="nav-title-row flex items-center">
            <text class="nav-brand text-gradient">AAFF 排行榜</text>
            <text class="sparkle-icon">✨</text>
          </view>
          <text class="nav-sub">AI Video Leaderboard</text>
        </view>
      </view>
      <view class="avatar-btn">
        <view class="avatar-placeholder">
          <text class="avatar-letter">{{avatarLetter}}</text>
        </view>
      </view>
    </view>

    <!-- Segmented Control -->
    <view class="seg-wrap">
      <view class="seg-bar glass-panel">
        <view
          class="seg-indicator"
          style="transform: translateX({{activeMainTab * 100}}%);"
        ></view>
        <view
          class="seg-item"
          bindtap="switchMainTab"
          data-index="0"
        >
          <text class="seg-label {{activeMainTab === 0 ? 'seg-active' : ''}}">AI 短片</text>
        </view>
        <view
          class="seg-item"
          bindtap="switchMainTab"
          data-index="1"
        >
          <text class="seg-label {{activeMainTab === 1 ? 'seg-active' : ''}}">AI 短剧</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Spacer for fixed nav -->
  <view style="height: {{navHeight + 100}}px;"></view>

  <!-- Scrollable Content -->
  <scroll-view
    class="main-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
    bindscrolltolower="onLoadMore"
  >
    <!-- Podium Section -->
    <view class="podium-section" wx:if="{{topItems.length >= 3}}">
      <view class="podium flex items-end justify-center">
        <!-- Rank 2 (Left) -->
        <view class="podium-col animate-spring" style="animation-delay: 0.1s;">
          <view class="podium-avatar-wrap">
            <view class="podium-ring ring-silver">
              <view class="podium-avatar-circle" style="background: linear-gradient(135deg, {{topItems[1].gradientFrom}}, {{topItems[1].gradientTo}});">
                <text class="podium-initial">{{topItems[1].initial}}</text>
              </view>
            </view>
            <view class="podium-name-bubble glass-panel">
              <text class="podium-name">{{topItems[1].author}}</text>
            </view>
            <text class="podium-score score-silver">{{topItems[1].score}}分</text>
          </view>
          <view class="pillar pillar-silver">
            <view class="pillar-shine"></view>
            <text class="pillar-num">2</text>
          </view>
        </view>

        <!-- Rank 1 (Center, Tall) -->
        <view class="podium-col podium-first animate-spring" style="animation-delay: 0s;">
          <view class="podium-avatar-wrap">
            <text class="crown-emoji">👑</text>
            <view class="podium-ring ring-gold">
              <view class="podium-avatar-circle" style="background: linear-gradient(135deg, {{topItems[0].gradientFrom}}, {{topItems[0].gradientTo}});">
                <text class="podium-initial">{{topItems[0].initial}}</text>
              </view>
            </view>
            <view class="podium-name-bubble glass-panel">
              <text class="podium-name">{{topItems[0].author}}</text>
            </view>
            <text class="podium-score score-gold">{{topItems[0].score}}分</text>
          </view>
          <view class="pillar pillar-gold">
            <view class="pillar-shine"></view>
            <text class="pillar-num">1</text>
          </view>
        </view>

        <!-- Rank 3 (Right) -->
        <view class="podium-col animate-spring" style="animation-delay: 0.2s;">
          <view class="podium-avatar-wrap">
            <view class="podium-ring ring-bronze">
              <view class="podium-avatar-circle" style="background: linear-gradient(135deg, {{topItems[2].gradientFrom}}, {{topItems[2].gradientTo}});">
                <text class="podium-initial">{{topItems[2].initial}}</text>
              </view>
            </view>
            <view class="podium-name-bubble glass-panel">
              <text class="podium-name">{{topItems[2].author}}</text>
            </view>
            <text class="podium-score score-bronze">{{topItems[2].score}}分</text>
          </view>
          <view class="pillar pillar-bronze">
            <view class="pillar-shine"></view>
            <text class="pillar-num">3</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Leaderboard Cards -->
    <view class="cards-section">
      <view
        class="lb-card animate-in"
        style="animation-delay: {{index * 0.06}}s;"
        wx:for="{{rankItems}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <!-- Background Gradient (CSS only, no images) -->
        <view class="lb-card-bg">
          <view class="lb-card-bg-gradient" style="background: linear-gradient(135deg, {{item.gradientFrom}}, {{item.gradientTo}});"></view>
          <view class="lb-card-bg-fade"></view>
        </view>

        <!-- Card Content -->
        <view class="lb-card-content">
          <!-- Header: Rank Badge + Title -->
          <view class="lb-header flex items-start">
            <!-- Rank Badge -->
            <view wx:if="{{item.rank <= 3}}" class="rank-badge-pennant {{item.badgeClass}}">
              <text class="pennant-top">TOP</text>
              <text class="pennant-num">{{item.rank}}</text>
            </view>
            <view wx:else class="rank-badge-simple">
              <text class="rank-badge-simple-num">{{item.rank}}</text>
            </view>

            <view class="lb-title-area flex-1">
              <text class="lb-title line-clamp-1">{{item.title}}</text>
              <text class="lb-author">作者: {{item.author}}</text>
            </view>
          </view>

          <!-- Stats Row -->
          <view class="lb-stats flex items-center">
            <!-- Approval Badge -->
            <view class="progress-wrap flex items-center">
              <view class="approval-badge" style="border-color: {{item.approvalColor}};">
                <text class="approval-num" style="color: {{item.approvalColor}};">{{item.approval}}</text>
              </view>
              <text class="progress-label">好评率</text>
            </view>

            <view class="stats-info flex flex-col">
              <view class="stat-line flex items-center">
                <text class="stat-icon-fire">🔥</text>
                <text class="stat-text-light">评分 {{item.score}}</text>
              </view>
              <view class="stat-line flex items-center">
                <text class="stat-icon-play">▶</text>
                <text class="stat-text-dim">播放 {{item.views}}</text>
              </view>
            </view>

            <!-- Tags -->
            <view class="lb-tags flex">
              <text class="lb-tag glass-panel" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
            </view>
          </view>

          <!-- Description Quote -->
          <view class="lb-quote" wx:if="{{item.description}}">
            <text class="quote-mark quote-open">"</text>
            <text class="quote-text line-clamp-2">{{item.description}}</text>
            <text class="quote-mark quote-close">"</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Load More -->
    <view class="load-more-area" wx:if="{{hasMore}}">
      <view class="pulse-dots flex justify-center items-center">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>
    </view>
    <view class="end-line" wx:else>
      <view class="end-divider"></view>
      <text class="end-text">已经到底了</text>
      <view class="end-divider"></view>
    </view>

    <!-- Safe area -->
    <view style="height: 200rpx;"></view>
  </scroll-view>
</view>
