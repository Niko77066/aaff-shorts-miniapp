<!--
  AAFF AI Video Rankings - Index Page
  Reference Design: AI Studio (floating pill nav, hero banner, podium)
-->
<view class="page">
  <!-- Background gradient orbs -->
  <view class="bg-gradient">
    <view class="bg-orb bg-orb-purple"></view>
    <view class="bg-orb bg-orb-rose"></view>
    <view class="bg-orb bg-orb-amber"></view>
    <view class="bg-orb bg-orb-blue"></view>
  </view>

  <!-- Header (sticky) -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-fade"></view>
    <view class="nav-bar-inner">
      <!-- Left: Logo + Brand -->
      <view class="nav-left flex items-center">
        <text class="nav-brand">AAFF</text>
      </view>
      <!-- Right: Search + Bell -->
      <view class="nav-right flex items-center">
        <view class="nav-icon-btn" bindtap="">
          <text class="icon nav-icon">\ue154</text>
        </view>
        <view class="nav-icon-btn" bindtap="">
          <text class="icon nav-icon">\ue05d</text>
        </view>
      </view>
    </view>

    <!-- Pill Tabs -->
    <view class="tab-pills flex">
      <view
        wx:for="{{tabs}}"
        wx:key="index"
        class="tab-pill {{activeMainTab === index ? 'tab-pill-active' : 'tab-pill-inactive'}}"
        bindtap="switchMainTab"
        data-index="{{index}}"
      >
        <text class="icon tab-pill-icon">{{tabIcons[index]}}</text>
        <text class="tab-pill-label">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- Spacer for fixed nav -->
  <view style="height: {{navHeight + 100}}px;"></view>

  <!-- Scrollable Content -->
  <scroll-view
    class="main-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
    bindscrolltolower="onLoadMore"
  >
    <!-- Content -->
    <view class="content-wrapper">

    <!-- Section Title -->
    <view class="section-title flex items-center justify-between">
      <text class="section-title-text">{{tabs[activeMainTab]}} 排行榜</text>
      <text class="section-title-badge">TOP {{rankItems.length}}</text>
    </view>

    <!-- Immersive Cover Cards -->
    <view class="cards-section">
      <view
        class="cover-card animate-in"
        style="animation-delay: {{index * 0.05}}s;"
        wx:for="{{rankItems}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <!-- Cover Image -->
        <image wx:if="{{item.cover}}" class="cover-card-img" src="{{item.cover}}" mode="aspectFill" />
        <view wx:else class="cover-card-placeholder"></view>

        <!-- Bottom gradient overlay -->
        <view class="cover-card-overlay"></view>

        <!-- Rank badge — top left -->
        <view class="cover-rank {{item.rank <= 1 ? 'cover-rank-1' : (item.rank <= 2 ? 'cover-rank-2' : (item.rank <= 3 ? 'cover-rank-3' : 'cover-rank-n'))}}">
          <text class="cover-rank-num">{{item.rankStr}}</text>
        </view>

        <!-- Duration — top right -->
        <view wx:if="{{item.score}}" class="cover-dur">
          <text class="cover-dur-text">{{item.score}}</text>
        </view>

        <!-- Play button — bottom right -->
        <view class="cover-play">
          <view class="cover-play-tri"></view>
        </view>

        <!-- Title + Author — bottom left -->
        <view class="cover-text">
          <text class="cover-title">{{item.title}}</text>
          <view class="cover-meta">
            <text class="cover-author">{{item.author}}</text>
            <view wx:if="{{item.views && item.views != '-'}}" class="cover-dot"></view>
            <text wx:if="{{item.views && item.views != '-'}}" class="cover-views">{{item.views}} 播放</text>
            <text wx:if="{{item.platform}}" class="cover-plat">{{item.platform}}</text>
          </view>
        </view>
      </view>
    </view>
    </view> <!-- end content-wrapper -->

    <!-- Load More -->
    <view class="load-more-area" wx:if="{{hasMore}}">
      <view class="pulse-dots flex justify-center items-center">
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
        <view class="pulse-dot"></view>
      </view>
    </view>
    <view class="end-line" wx:else>
      <view class="end-divider"></view>
      <text class="end-text">已经到底了</text>
      <view class="end-divider"></view>
    </view>

    <!-- Safe area for floating nav -->
    <view style="height: 240rpx;"></view>
  </scroll-view>
</view>
