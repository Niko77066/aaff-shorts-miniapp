/* ════════════════════════════════════════
   Index Page — AI Studio Reference Design
   ════════════════════════════════════════ */

.page {
  min-height: 100vh;
  background: #0a0510;
  position: relative;
  overflow: hidden;
}

/* ─── Background Gradient Orbs ─── */
.bg-gradient {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}
.bg-orb {
  position: absolute;
  border-radius: 50%;
}
.bg-orb-purple {
  top: -10%;
  left: -20%;
  width: 70%;
  height: 50%;
  background: rgba(88, 28, 135, 0.4);
  filter: blur(120px);
  -webkit-filter: blur(120px);
}
.bg-orb-rose {
  top: 5%;
  right: -20%;
  width: 60%;
  height: 60%;
  background: rgba(136, 19, 55, 0.3);
  filter: blur(120px);
  -webkit-filter: blur(120px);
}
.bg-orb-amber {
  top: 20%;
  left: 10%;
  width: 80%;
  height: 40%;
  background: rgba(180, 83, 9, 0.2);
  filter: blur(150px);
  -webkit-filter: blur(150px);
}
.bg-orb-blue {
  bottom: -10%;
  left: 10%;
  width: 80%;
  height: 50%;
  background: rgba(30, 58, 138, 0.2);
  filter: blur(120px);
  -webkit-filter: blur(120px);
}

/* ─── Header ─── */
.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding-bottom: 16rpx;
}
.nav-bar-fade {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(10, 5, 16, 0.95) 0%, rgba(10, 5, 16, 0.80) 60%, transparent 100%);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  z-index: -1;
}
.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  padding: 0 32rpx;
}
.nav-left {
  gap: 16rpx;
}
.nav-logo-mark {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
}
.nav-brand {
  font-size: 38rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 8rpx;
}
.nav-right {
  gap: 24rpx;
}
.nav-icon-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-icon-emoji {
  font-size: 36rpx;
  opacity: 0.5;
}

/* ─── Pill Tabs ─── */
.tab-pills {
  padding: 0 32rpx;
  gap: 16rpx;
}
.tab-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}
.tab-pill-icon {
  font-size: 28rpx;
}
.tab-pill-label {
  font-size: 26rpx;
  font-weight: 600;
}
.tab-pill-active {
  background: #FFFFFF;
  color: #000000;
  box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.2);
}
.tab-pill-active .tab-pill-label {
  color: #000000;
}
.tab-pill-inactive {
  background: rgba(255, 255, 255, 0.05);
  color: #a1a1aa;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
.tab-pill-inactive .tab-pill-label {
  color: #a1a1aa;
}

/* ─── Main Scroll ─── */
.main-scroll {
  height: calc(100vh - 200rpx);
  position: relative;
  z-index: 1;
}

/* ─── Hero Banner ─── */
.hero-banner-section {
  padding: 16rpx 24rpx 0;
}
.hero-banner {
  width: 100%;
  height: 420rpx;
  border-radius: 48rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
}
.hero-banner-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
}
.hero-banner-overlay-top {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.2) 0%, transparent 40%, transparent 100%);
  z-index: 1;
}
.hero-banner-overlay-bottom {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to top, #0a0510 0%, rgba(10, 5, 16, 0.6) 40%, transparent 100%);
  z-index: 1;
}
.hero-banner-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 36rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.hero-banner-badge {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}
.hero-banner-badge-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.hero-banner-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1.15;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
  margin-bottom: 6rpx;
}
.hero-banner-author {
  font-size: 26rpx;
  color: #d4d4d8;
  font-weight: 500;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}
.hero-banner-desc {
  font-size: 22rpx;
  color: #a1a1aa;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.hero-banner-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #FFFFFF;
  color: #000000;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.3);
}
.hero-banner-btn-icon {
  font-size: 22rpx;
  color: #000000;
}
.hero-banner-btn-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #000000;
}

/* ─── Section Title ─── */
.section-title {
  padding: 32rpx 32rpx 16rpx;
}
.section-title-text {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}
.section-title-badge {
  font-size: 22rpx;
  font-weight: 500;
  color: #71717a;
}

/* ─── Podium ─── */
.podium {
  padding: 24rpx 32rpx 0;
  height: 360rpx;
  gap: 16rpx;
}
.podium-item {
  flex: 1;
  position: relative;
}
.podium-crown {
  font-size: 36rpx;
  margin-bottom: -6rpx;
  text-shadow: 0 0 16rpx rgba(251, 191, 36, 0.8);
  z-index: 20;
}

/* Avatar Ring */
.podium-avatar-ring {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  padding: 4rpx;
  margin-bottom: 10rpx;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}
.podium-ring-gold {
  background: linear-gradient(135deg, #fbbf24, #fde68a);
}
.podium-ring-silver {
  background: linear-gradient(135deg, #a1a1aa, #f4f4f5);
}
.podium-ring-bronze {
  background: linear-gradient(135deg, #ea580c, #fdba74);
}
.podium-avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #1a0b2e;
  border: 3rpx solid #1a0b2e;
  display: flex;
  align-items: center;
  justify-content: center;
}
.podium-avatar-letter {
  font-size: 30rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.7);
}

/* Name Bubble */
.podium-name-bubble {
  background: rgba(0, 0, 0, 0.5);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}
.podium-name {
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

/* Podium Scores */
.podium-score {
  font-size: 18rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.podium-score-gold {
  color: #fcd34d;
  text-shadow: 0 2rpx 10rpx rgba(251, 191, 36, 0.5);
}
.podium-score-silver {
  color: #e4e4e7;
  text-shadow: 0 2rpx 10rpx rgba(161, 161, 170, 0.5);
}
.podium-score-bronze {
  color: #fb923c;
  text-shadow: 0 2rpx 10rpx rgba(217, 119, 6, 0.5);
}

/* Pillar */
.podium-pillar {
  width: 100%;
  border-radius: 20rpx 20rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 16rpx;
  position: relative;
  overflow: hidden;
  border-top: 1rpx solid transparent;
  border-left: 1rpx solid transparent;
  border-right: 1rpx solid transparent;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.3);
}
.pillar-gold {
  height: 128rpx;
  background: linear-gradient(180deg, rgba(251, 191, 36, 0.3) 0%, rgba(251, 191, 36, 0) 100%);
  border-color: rgba(251, 191, 36, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
.pillar-silver {
  height: 96rpx;
  background: linear-gradient(180deg, rgba(161, 161, 170, 0.3) 0%, rgba(161, 161, 170, 0) 100%);
  border-color: rgba(161, 161, 170, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
.pillar-bronze {
  height: 80rpx;
  background: linear-gradient(180deg, rgba(217, 119, 6, 0.3) 0%, rgba(217, 119, 6, 0) 100%);
  border-color: rgba(217, 119, 6, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
.pillar-shine {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx;
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.5), transparent);
}
.pillar-rank {
  font-size: 64rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

/* ─── Leaderboard Cards (KEEP existing design) ─── */
.cards-section {
  padding: 24rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.lb-card {
  border-radius: var(--radius-2xl);
  overflow: hidden;
  position: relative;
  background: #242426;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: var(--shadow-lg);
  opacity: 0;
}

/* Card Background Gradient */
.lb-card-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 280rpx;
  overflow: hidden;
  z-index: 0;
}
.lb-card-bg-gradient {
  width: 100%;
  height: 100%;
  opacity: 0.30;
}
.lb-card-bg-fade {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(36, 36, 38, 0.60) 50%, #242426 100%);
}

/* Card Content */
.lb-card-content {
  position: relative;
  z-index: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Header */
.lb-header {
  gap: 18rpx;
  padding-top: 180rpx;
}

/* Rank Badge — Pennant (CSS only) */
.rank-badge-pennant {
  position: relative;
  width: 72rpx;
  height: 84rpx;
  flex-shrink: 0;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 8rpx;
}
.rank-badge-pennant.badge-gold {
  background: linear-gradient(180deg, #FDE68A 0%, #F59E0B 50%, #D97706 100%);
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.3);
}
.rank-badge-pennant.badge-silver {
  background: linear-gradient(180deg, #F4F4F5 0%, #A1A1AA 50%, #71717A 100%);
  box-shadow: 0 4rpx 16rpx rgba(161, 161, 170, 0.3);
}
.rank-badge-pennant.badge-bronze {
  background: linear-gradient(180deg, #FDBA74 0%, #EA580C 50%, #9A3412 100%);
  box-shadow: 0 4rpx 16rpx rgba(234, 88, 12, 0.3);
}
.pennant-top {
  font-size: 14rpx;
  font-weight: 900;
  color: rgba(120, 53, 15, 0.8);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  line-height: 1.2;
}
.pennant-num {
  font-size: 36rpx;
  font-weight: 900;
  color: #78350f;
  line-height: 1;
}

/* Rank Badge — Simple (4+) */
.rank-badge-simple {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rank-badge-simple-num {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-secondary);
}

/* Title Area */
.lb-title-area {
  padding-top: 6rpx;
}
.lb-title {
  font-size: var(--font-lg);
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}
.lb-author {
  font-size: var(--font-sm);
  color: #d4d4d8;
  margin-top: 8rpx;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

/* Stats Row */
.lb-stats {
  gap: 20rpx;
}
.progress-wrap {
  gap: 10rpx;
}
.approval-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}
.approval-num {
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}
.progress-label {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.stats-info {
  gap: 6rpx;
}
.stat-line {
  gap: 8rpx;
}
.stat-icon-fire {
  font-size: 22rpx;
}
.stat-icon-play {
  font-size: 18rpx;
  color: #60a5fa;
}
.stat-text-light {
  font-size: 22rpx;
  font-weight: 500;
  color: #d4d4d8;
}
.stat-text-dim {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* Tags */
.lb-tags {
  margin-left: auto;
  gap: 10rpx;
  align-self: flex-end;
}
.lb-tag {
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

/* Description Quote */
.lb-quote {
  position: relative;
  background: rgba(0, 0, 0, 0.20);
  border-radius: var(--radius-xl);
  padding: 20rpx 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.04);
}
.quote-mark {
  font-size: 40rpx;
  color: var(--color-text-tertiary);
  font-family: serif;
  line-height: 1;
}
.quote-open {
  position: absolute;
  top: 14rpx;
  left: 16rpx;
}
.quote-close {
  position: absolute;
  bottom: 4rpx;
  right: 16rpx;
}
.quote-text {
  font-size: 22rpx;
  color: #d4d4d8;
  padding-left: 36rpx;
  padding-right: 24rpx;
  line-height: 1.6;
}

/* ─── Load More ─── */
.load-more-area {
  padding: 48rpx 0;
}
.pulse-dots {
  gap: 16rpx;
}
.pulse-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-accent);
  opacity: 0.4;
  animation: pulse 1.4s infinite ease-in-out;
}
.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40% { transform: scale(1); opacity: 0.8; }
}

.end-line {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 20rpx;
}
.end-divider {
  width: 60rpx;
  height: 2rpx;
  background: var(--color-border-strong);
  border-radius: 1rpx;
}
.end-text {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  font-weight: 500;
}
