.page {
  min-height: 100vh;
  background: #0a0510;
  position: relative;
  overflow: hidden;
}

/* ─── New Centered Header ─── */
.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
}
.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: center; /* Center the content */
  height: 96rpx;
  padding: 0 32rpx;
  position: relative; /* For avatar positioning */
}
.nav-left {
  text-align: center;
}
.nav-brand {
  font-size: 40rpx;
  font-weight: 900;
  color: #FFFFFF;
}
.nav-sub {
  font-size: 18rpx;
  color: #a1a1aa; /* zinc-400 */
  font-weight: 500;
  margin-top: 2rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* Avatar */
.avatar-btn {
  position: absolute;
  top: 50%;
  right: 32rpx;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}
.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #60a5fa, #818cf8);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-letter {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFFFFF;
}

/* ─── Thinner Segmented Control ─── */
.seg-wrap {
  padding: 12rpx 48rpx 20rpx; /* More horizontal padding */
}
.seg-bar {
  position: relative;
  display: flex;
  border-radius: var(--radius-full);
  padding: 6rpx; /* Thinner padding */
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.10);
}
.seg-indicator {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(50% - 6rpx);
  height: calc(100% - 12rpx);
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-full);
  transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  z-index: 1;
}
.seg-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx; /* Shorter height */
  z-index: 2;
  position: relative;
}
.seg-label {
  font-size: var(--font-sm); /* Smaller font */
  font-weight: 500;
  color: var(--color-text-secondary);
  transition: color 0.3s;
}
.seg-active {
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ─── Main Scroll ─── */
.main-scroll {
  height: calc(100vh - 200rpx);
  position: relative;
  z-index: 1;
}

/* ─── Podium Section ─── */
.podium-section {
  padding: 60rpx 32rpx 0;
}
.podium {
  gap: 16rpx;
  height: 420rpx;
}
.podium-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
}
.podium-first {
  margin-top: -40rpx;
}

/* Avatar Ring */
.podium-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
  z-index: 10;
  position: relative;
}
.podium-ring {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  padding: 4rpx;
  box-shadow: var(--shadow-lg);
}
.ring-gold {
  background: linear-gradient(135deg, #f59e0b, #fde68a);
}
.ring-silver {
  background: linear-gradient(135deg, #71717a, #f4f4f5);
}
.ring-bronze {
  background: linear-gradient(135deg, #ea580c, #fdba74);
}
.podium-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid #1a0b2e;
}
.podium-avatar-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid #1a0b2e;
  display: flex;
  align-items: center;
  justify-content: center;
}
.podium-initial {
  font-size: 36rpx;
  font-weight: 900;
  color: #FFFFFF;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

/* Crown */
.crown-emoji {
  position: absolute;
  top: -40rpx;
  font-size: 36rpx;
  z-index: 20;
  filter: drop-shadow(0 0 8px rgba(251, 191, 36, 0.8));
}

/* Name Bubble */
.podium-name-bubble {
  margin-top: 10rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  background: rgba(0, 0, 0, 0.50) !important;
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.10) !important;
}
.podium-name {
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

/* Podium Score */
.podium-score {
  font-size: 18rpx;
  font-weight: 700;
  margin-top: 6rpx;
}
.score-gold {
  color: #fbbf24;
  text-shadow: 0 2px 10px rgba(251, 191, 36, 0.5);
}
.score-silver {
  color: #e4e4e7;
  text-shadow: 0 2px 10px rgba(161, 161, 170, 0.5);
}
.score-bronze {
  color: #fb923c;
  text-shadow: 0 2px 10px rgba(217, 119, 6, 0.5);
}

/* Pillars */
.pillar {
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  justify-content: center;
  padding-top: 16rpx;
  position: relative;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
.pillar-gold {
  height: 240rpx;
  background: linear-gradient(180deg, rgba(251, 191, 36, 0.30) 0%, rgba(251, 191, 36, 0) 100%);
  border-top: 2rpx solid rgba(251, 191, 36, 0.30);
  border-left: 2rpx solid rgba(251, 191, 36, 0.30);
  border-right: 2rpx solid rgba(251, 191, 36, 0.30);
}
.pillar-silver {
  height: 180rpx;
  background: linear-gradient(180deg, rgba(161, 161, 170, 0.30) 0%, rgba(161, 161, 170, 0) 100%);
  border-top: 2rpx solid rgba(161, 161, 170, 0.30);
  border-left: 2rpx solid rgba(161, 161, 170, 0.30);
  border-right: 2rpx solid rgba(161, 161, 170, 0.30);
}
.pillar-bronze {
  height: 150rpx;
  background: linear-gradient(180deg, rgba(217, 119, 6, 0.30) 0%, rgba(217, 119, 6, 0) 100%);
  border-top: 2rpx solid rgba(217, 119, 6, 0.30);
  border-left: 2rpx solid rgba(217, 119, 6, 0.30);
  border-right: 2rpx solid rgba(217, 119, 6, 0.30);
}
.pillar-shine {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx;
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.5), transparent);
}
.pillar-num {
  font-size: 72rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* ─── Leaderboard Cards ─── */
.cards-section {
  padding: 32rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.lb-card {
  border-radius: var(--radius-2xl);
  overflow: hidden;
  position: relative;
  background: #242426;
  border: 2rpx solid rgba(255, 255, 255, 0.10);
  box-shadow: var(--shadow-lg);
  opacity: 0;
}

/* Card Background Gradient */
.lb-card-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 280rpx;
  overflow: hidden;
  z-index: 0;
}
.lb-card-bg-gradient {
  width: 100%;
  height: 100%;
  opacity: 0.35;
}
.lb-card-bg-fade {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(36, 36, 38, 0.60) 50%, #242426 100%);
}

/* Card Content */
.lb-card-content {
  position: relative;
  z-index: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Header */
.lb-header {
  gap: 18rpx;
  padding-top: 180rpx;
}

/* Rank Badge — Pennant (CSS only) */
.rank-badge-pennant {
  position: relative;
  width: 72rpx;
  height: 84rpx;
  flex-shrink: 0;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 8rpx;
}
.rank-badge-pennant.badge-gold {
  background: linear-gradient(180deg, #FDE68A 0%, #F59E0B 50%, #D97706 100%);
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.3);
}
.rank-badge-pennant.badge-silver {
  background: linear-gradient(180deg, #F4F4F5 0%, #A1A1AA 50%, #71717A 100%);
  box-shadow: 0 4rpx 16rpx rgba(161, 161, 170, 0.3);
}
.rank-badge-pennant.badge-bronze {
  background: linear-gradient(180deg, #FDBA74 0%, #EA580C 50%, #9A3412 100%);
  box-shadow: 0 4rpx 16rpx rgba(234, 88, 12, 0.3);
}
.pennant-top {
  font-size: 14rpx;
  font-weight: 900;
  color: rgba(120, 53, 15, 0.8);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  line-height: 1.2;
}
.pennant-num {
  font-size: 36rpx;
  font-weight: 900;
  color: #78350f;
  line-height: 1;
}

/* Rank Badge — Simple (4+) */
.rank-badge-simple {
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rank-badge-simple-num {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-secondary);
}

/* Title Area */
.lb-title-area {
  padding-top: 6rpx;
}
.lb-title {
  font-size: var(--font-lg);
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}
.lb-author {
  font-size: var(--font-sm);
  color: #d4d4d8;
  margin-top: 8rpx;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

/* Stats Row */
.lb-stats {
  gap: 20rpx;
}
.progress-wrap {
  gap: 10rpx;
}
.approval-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}
.approval-num {
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}
.progress-label {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.stats-info {
  gap: 6rpx;
}
.stat-line {
  gap: 8rpx;
}
.stat-icon-fire {
  font-size: 22rpx;
}
.stat-icon-play {
  font-size: 18rpx;
  color: #60a5fa;
}
.stat-text-light {
  font-size: 22rpx;
  font-weight: 500;
  color: #d4d4d8;
}
.stat-text-dim {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* Tags */
.lb-tags {
  margin-left: auto;
  gap: 10rpx;
  align-self: flex-end;
}
.lb-tag {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.10) !important;
  border: 1px solid rgba(255, 255, 255, 0.10) !important;
}

/* Description Quote */
.lb-quote {
  position: relative;
  background: rgba(0, 0, 0, 0.20);
  border-radius: var(--radius-xl);
  padding: 20rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}
.quote-mark {
  font-size: 40rpx;
  color: var(--color-text-tertiary);
  font-family: serif;
  line-height: 1;
}
.quote-open {
  position: absolute;
  top: 14rpx;
  left: 16rpx;
}
.quote-close {
  position: absolute;
  bottom: 4rpx;
  right: 16rpx;
}
.quote-text {
  font-size: 22rpx;
  color: #d4d4d8;
  padding-left: 36rpx;
  padding-right: 24rpx;
  line-height: 1.6;
}

/* ─── Load More ─── */
.load-more-area {
  padding: 48rpx 0;
}
.pulse-dots {
  gap: 16rpx;
}
.pulse-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-accent);
  opacity: 0.4;
  animation: pulse 1.4s infinite ease-in-out;
}
.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40% { transform: scale(1); opacity: 0.8; }
}

.end-line {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 20rpx;
}
.end-divider {
  width: 60rpx;
  height: 2rpx;
  background: var(--color-border-strong);
  border-radius: 1rpx;
}
.end-text {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  font-weight: 500;
}
