/* ════════════════════════════════════════
   Index Page — Pixel-perfect translation from App.tsx
   ════════════════════════════════════════ */

.page {
  min-height: 100vh;
  background: #0A0F14;
  position: relative;
  overflow: hidden;
  padding-bottom: 160rpx;
}

/* ─── Background Gradient Orbs ─── */
.bg-gradient {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
  background: #0A0F14;
}
.bg-orb {
  position: absolute;
  border-radius: 50%;
}
.bg-orb-purple {
  top: -10%;
  left: -20%;
  width: 70%;
  height: 50%;
  background: rgba(0, 168, 150, 0.25); /* emerald/40 */
  filter: blur(180px);
  -webkit-filter: blur(180px);
}
.bg-orb-rose {
  top: 5%;
  right: -20%;
  width: 60%;
  height: 60%;
  background: rgba(255, 184, 0, 0.15); /* amber/30 */
  filter: blur(180px);
  -webkit-filter: blur(180px);
}
.bg-orb-amber {
  top: 20%;
  left: 10%;
  width: 80%;
  height: 40%;
  background: rgba(255, 184, 0, 0.10); /* amber/20 */
  filter: blur(200px);
  -webkit-filter: blur(200px);
}
.bg-orb-blue {
  bottom: -10%;
  left: 10%;
  width: 80%;
  height: 50%;
  background: rgba(0, 168, 150, 0.12); /* emerald/20 */
  filter: blur(180px);
  -webkit-filter: blur(180px);
}

/* ─── Header (sticky) ─── */
/* Reference: pt-12 pb-4 px-6 sticky top-0 z-40 bg-transparent */
.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 40;
  padding-bottom: 16rpx; /* pb-4 → 16rpx */
  padding-left: 24rpx;  /* px-6 → 24rpx */
  padding-right: 24rpx;
}
/* Reference: absolute inset-0 bg-gradient-to-b from-[#0a0510]/95 via-[#0a0510]/80 to-transparent backdrop-blur-md */
.nav-bar-fade {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(10, 15, 20, 0.65);
  -webkit-backdrop-filter: blur(40rpx);
  backdrop-filter: blur(40rpx);
  z-index: -1;
}

/* Reference: flex items-center justify-between mb-6 */
.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx; /* mb-6 → 24rpx */
}

/* Reference: flex items-center gap-3 */
.nav-left {
  gap: 12rpx; /* gap-3 → 12rpx */
}
/* Reference: w-8 h-8 text-white drop-shadow */
.nav-logo-mark {
  width: 64rpx;  /* w-8 → 64rpx */
  height: 64rpx; /* h-8 → 64rpx */
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #FFFFFF;
  filter: drop-shadow(0 0 20rpx rgba(255, 255, 255, 0.3));
}
/* Reference: text-xl font-bold tracking-widest text-white */
.nav-brand {
  font-size: 40rpx;   /* text-xl → 40rpx */
  font-weight: 700;    /* font-bold → 700 */
  letter-spacing: 4rpx; /* tracking-widest → 4rpx */
  color: #FFFFFF;
}

/* Reference: flex items-center gap-5 */
.nav-right {
  gap: 20rpx; /* gap-5 → 20rpx */
}
/* Reference: text-zinc-400 (button container) */
.nav-icon-btn {
  width: 40rpx;  /* w-5 → 40rpx (icon size) */
  height: 40rpx; /* h-5 → 40rpx */
  display: flex;
  align-items: center;
  justify-content: center;
}
/* Reference: w-5 h-5 strokeWidth 1.5, text-zinc-400 */
.nav-icon {
  font-size: 40rpx;
  color: #8B949E; /* text-secondary */
}

/* ─── Pill Tabs ─── */
/* Reference: flex gap-3 relative z-30 */
.tab-pills {
  padding: 0 0 16rpx 0;
  gap: 12rpx;
  position: relative;
  z-index: 30;
}
/* Reference: flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium */
.tab-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;           /* gap-2 → 8rpx */
  padding: 10rpx 20rpx; /* py-2.5 px-5 → 10rpx 20rpx */
  border-radius: 999rpx; /* rounded-full */
  font-size: 28rpx;     /* text-sm → 28rpx */
  font-weight: 500;      /* font-medium → 500 */
  transition: all 0.3s ease;
}
.tab-pill-icon {
  font-size: 28rpx; /* w-4 h-4 icon → 28rpx for emoji */
}
.tab-pill-label {
  font-size: 28rpx; /* text-sm → 28rpx */
  font-weight: 500;  /* font-medium → 500 */
}
/* Reference active: bg-white text-black shadow-[0_0_20px_rgba(255,255,255,0.2)] */
.tab-pill-active {
  background: #FFFFFF;
  color: #000000;
  box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.2);
}
.tab-pill-active .tab-pill-icon {
  color: #000000;
}
.tab-pill-active .tab-pill-label {
  color: #000000;
}
/* Reference inactive: bg-white/5 text-zinc-400 border border-white/10 */
.tab-pill-inactive {
  background: rgba(255, 255, 255, 0.05);
  color: #8B949E;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}
.tab-pill-inactive .tab-pill-icon {
  color: #8B949E;
}
.tab-pill-inactive .tab-pill-label {
  color: #8B949E;
}

/* ─── Main Scroll ─── */
.main-scroll {
  height: calc(100vh - 200rpx);
  position: relative;
  z-index: 1;
}

/* ─── Main Content ─── */
/* Reference: flex-1 px-4 pt-2 → flex flex-col gap-4 */
.content-wrapper {
  padding: 0 16rpx;
  padding-top: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx; /* gap-4 → 16rpx */
}

.content-area {
  padding: 0 16rpx; /* px-4 → 16rpx */
  padding-top: 8rpx; /* pt-2 → 8rpx */
}

/* ─── Hero Banner ─── */
/* No extra padding - parent content-wrapper handles px-4 */
.hero-banner-section {
  padding: 0;
}
/* Reference: relative w-full h-[420px] rounded-3xl overflow-hidden shadow-2xl border border-white/10 */
.hero-banner {
  width: 100%;
  height: 840rpx;     /* h-[420px] → 840rpx */
  border-radius: 48rpx; /* rounded-3xl → 48rpx */
  overflow: hidden;
  position: relative;
  border: 2rpx solid rgba(255, 255, 255, 0.1); /* border-white/10 */
  box-shadow: 0 50rpx 100rpx rgba(0, 0, 0, 0.5); /* shadow-2xl */
}
.hero-banner-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
}
/* Reference: absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-[#0a0510] opacity-90 */
.hero-banner-overlay-top {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.2) 0%, transparent 50%, #0A0F14 100%);
  opacity: 0.9;
  z-index: 1;
}
/* Reference: absolute inset-0 bg-gradient-to-t from-[#0a0510] via-[#0a0510]/60 to-transparent opacity-90 */
.hero-banner-overlay-bottom {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to top, #0A0F14 0%, rgba(10, 15, 20, 0.6) 40%, transparent 100%);
  opacity: 0.9;
  z-index: 1;
}
/* Reference: absolute bottom-0 left-0 right-0 p-6 flex flex-col items-start z-10 */
.hero-banner-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx; /* p-6 → 24rpx */
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
/* Reference: px-3 py-1.5 bg-white/10 backdrop-blur-md rounded-full text-[10px] font-bold text-white mb-3 border border-white/20 shadow-lg */
.hero-banner-badge {
  padding: 6rpx 12rpx; /* py-1.5 px-3 → 6rpx 12rpx */
  background: rgba(255, 255, 255, 0.1);
  -webkit-backdrop-filter: blur(24rpx); /* backdrop-blur-md */
  backdrop-filter: blur(24rpx);
  border-radius: 999rpx; /* rounded-full */
  border: 2rpx solid rgba(255, 255, 255, 0.2); /* border-white/20 */
  margin-bottom: 12rpx; /* mb-3 → 12rpx */
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25); /* shadow-lg */
}
.hero-banner-badge-text {
  font-size: 20rpx;  /* text-[10px] → 20rpx */
  font-weight: 700;   /* font-bold → 700 */
  color: #FFFFFF;
}
/* Reference: text-3xl font-black text-white mb-1 drop-shadow-lg leading-tight */
.hero-banner-title {
  font-size: 60rpx;   /* text-3xl → 60rpx */
  font-weight: 900;    /* font-black → 900 */
  color: #FFFFFF;
  line-height: 1.25;   /* leading-tight → 1.25 */
  filter: drop-shadow(0 20rpx 26rpx rgba(0, 0, 0, 0.25)); /* drop-shadow-lg */
  margin-bottom: 4rpx; /* mb-1 → 4rpx */
}
/* Reference: text-sm text-zinc-300 mb-3 drop-shadow-md font-medium */
.hero-banner-author {
  font-size: 28rpx;   /* text-sm → 28rpx */
  color: #E6EDF3;      /* text-zinc-300 */
  font-weight: 500;    /* font-medium → 500 */
  margin-bottom: 12rpx; /* mb-3 → 12rpx */
  filter: drop-shadow(0 8rpx 12rpx rgba(0, 0, 0, 0.25)); /* drop-shadow-md */
}
/* Reference: text-xs text-zinc-400 mb-6 line-clamp-2 leading-relaxed */
.hero-banner-desc {
  font-size: 24rpx;   /* text-xs → 24rpx */
  color: #8B949E;      /* text-zinc-400 */
  line-height: 1.625;  /* leading-relaxed → 1.625 */
  margin-bottom: 24rpx; /* mb-6 → 24rpx */
}
/* Reference: flex items-center gap-2 bg-white text-black px-6 py-3 rounded-full font-bold text-sm shadow-[0_0_20px_rgba(255,255,255,0.3)] */
.hero-banner-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;           /* gap-2 → 8rpx */
  background: #FFFFFF;
  color: #000000;
  padding: 12rpx 24rpx; /* py-3 px-6 → 12rpx 24rpx */
  border-radius: 999rpx; /* rounded-full */
  box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.3);
  font-weight: 700;     /* font-bold → 700 */
}
/* Reference: w-4 h-4 fill-black (Play icon) */
.hero-banner-btn-icon {
  font-size: 24rpx;
  color: #000000;
}
/* Reference: text-sm font-bold */
.hero-banner-btn-text {
  font-size: 28rpx; /* text-sm → 28rpx */
  font-weight: 700;  /* font-bold → 700 */
  color: #000000;
}

/* ─── Section Title ─── */
/* Reference: mt-4 mb-2 flex items-center justify-between px-2 */
.section-title {
  margin-top: 24rpx;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}
/* Reference: text-lg font-bold text-white tracking-wide */
.section-title-text {
  font-size: 36rpx;   /* text-lg → 36rpx */
  font-weight: 700;    /* font-bold → 700 */
  color: #FFFFFF;
  letter-spacing: 2rpx; /* tracking-wide → 2rpx */
}
/* Reference: text-xs text-zinc-500 font-medium */
.section-title-badge {
  font-size: 24rpx;  /* text-xs → 24rpx */
  font-weight: 500;   /* font-medium → 500 */
  color: #484F58;      /* text-zinc-500 */
}

/* ─── Podium ─── */
/* Reference: flex items-end justify-center gap-2 mt-4 mb-0 h-44 px-4 */
.podium {
  padding: 0 16rpx; /* px-4 → 16rpx (Podium's own padding, on top of parent px-4) */
  height: 352rpx;   /* h-44 → 352rpx */
  gap: 8rpx;         /* gap-2 → 8rpx */
  margin-top: 16rpx; /* mt-4 → 16rpx */
  margin-bottom: 0;
}
/* Reference: flex flex-col items-center flex-1 relative */
.podium-item {
  flex: 1;
  position: relative;
}

/* Reference: relative mb-2 z-10 flex flex-col items-center */
.podium-avatar-area {
  position: relative;
  margin-bottom: 8rpx; /* mb-2 → 8rpx */
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Reference: absolute -top-5 text-xl drop-shadow z-20 */
.podium-crown-icon {
  font-size: 40rpx;
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #FFB800;
  text-shadow: 0 0 16rpx rgba(255, 184, 0, 0.8);
  z-index: 20;
}

/* Avatar Ring */
/* Reference: w-12 h-12 rounded-full p-0.5 */
.podium-avatar-ring {
  width: 96rpx;  /* w-12 → 96rpx */
  height: 96rpx; /* h-12 → 96rpx */
  border-radius: 50%;
  padding: 2rpx; /* p-0.5 → 2rpx */
  z-index: 10;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25); /* shadow-lg */
}
/* Reference: bg-gradient-to-tr from-amber-500 to-yellow-200 */
.podium-ring-gold {
  background: linear-gradient(to top right, #FFB800, #FFD666);
}
/* Reference: bg-gradient-to-tr from-zinc-400 to-zinc-100 */
.podium-ring-silver {
  background: linear-gradient(to top right, #8B949E, #E6EDF3);
}
/* Reference: bg-gradient-to-tr from-orange-600 to-orange-300 */
.podium-ring-bronze {
  background: linear-gradient(to top right, #D29922, #F0D87E);
}
.podium-avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #161B22;
  border: 3rpx solid #161B22; /* border-[1.5px] */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.podium-avatar-letter {
  font-size: 30rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.7);
}

/* Name Bubble */
/* Reference: mt-1.5 bg-black/50 backdrop-blur-md px-2 py-0.5 rounded-full border border-white/10 shadow-xl */
.podium-name-bubble {
  margin-top: 6rpx;   /* mt-1.5 → 6rpx */
  background: rgba(0, 0, 0, 0.5); /* bg-black/50 */
  -webkit-backdrop-filter: blur(24rpx); /* backdrop-blur-md */
  backdrop-filter: blur(24rpx);
  padding: 2rpx 8rpx; /* py-0.5 px-2 → 2rpx 8rpx */
  border-radius: 999rpx; /* rounded-full */
  border: 2rpx solid rgba(255, 255, 255, 0.1); /* border-white/10 */
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.35); /* shadow-xl */
  margin-bottom: 0;
}
/* Reference: text-[9px] font-medium text-white/90 truncate max-w-[60px] text-center */
.podium-name {
  font-size: 18rpx;   /* text-[9px] → 18rpx */
  font-weight: 500;    /* font-medium → 500 */
  color: rgba(255, 255, 255, 0.9); /* text-white/90 */
  max-width: 120rpx;   /* max-w-[60px] → 120rpx */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

/* Podium Scores */
/* Reference: text-[9px] font-bold mt-0.5 */
.podium-score {
  font-size: 18rpx;  /* text-[9px] → 18rpx */
  font-weight: 700;   /* font-bold → 700 */
  margin-top: 2rpx;   /* mt-0.5 → 2rpx */
  margin-bottom: 0;
}
/* Reference: text-amber-300, textShadow 0 2px 10px rgba(251,191,36,0.5) */
.podium-score-gold {
  color: #FFD666;
  text-shadow: 0 4rpx 20rpx rgba(255, 184, 0, 0.5);
}
/* Reference: text-zinc-200 */
.podium-score-silver {
  color: #E6EDF3;
  text-shadow: 0 4rpx 20rpx rgba(139, 148, 158, 0.5);
}
/* Reference: text-orange-400 */
.podium-score-bronze {
  color: #F0D87E;
  text-shadow: 0 4rpx 20rpx rgba(210, 153, 34, 0.5);
}

/* Pillar */
/* Reference: w-full {height} rounded-t-xl backdrop-blur-md border-t border-l border-r {borderColor} flex justify-center pt-2 relative shadow-[0_-4px_20px_rgba(0,0,0,0.3)] */
.podium-pillar {
  width: 100%;
  border-radius: 24rpx 24rpx 0 0; /* rounded-t-xl → 24rpx */
  -webkit-backdrop-filter: blur(24rpx); /* backdrop-blur-md */
  backdrop-filter: blur(24rpx);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 8rpx; /* pt-2 → 8rpx */
  position: relative;
  overflow: hidden;
  border-top: 2rpx solid transparent;
  border-left: 2rpx solid transparent;
  border-right: 2rpx solid transparent;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.3);
}
/* Reference: h-32 → 256rpx */
.pillar-gold {
  height: 256rpx;
  background: linear-gradient(180deg, rgba(255, 184, 0, 0.3) 0%, rgba(255, 184, 0, 0) 100%);
  border-color: rgba(255, 184, 0, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
/* Reference: h-24 → 192rpx */
.pillar-silver {
  height: 192rpx;
  background: linear-gradient(180deg, rgba(139, 148, 158, 0.3) 0%, rgba(139, 148, 158, 0) 100%);
  border-color: rgba(139, 148, 158, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
/* Reference: h-20 → 160rpx */
.pillar-bronze {
  height: 160rpx;
  background: linear-gradient(180deg, rgba(210, 153, 34, 0.3) 0%, rgba(210, 153, 34, 0) 100%);
  border-color: rgba(210, 153, 34, 0.3);
  -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
}
/* Reference: absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-white/50 to-transparent */
.pillar-shine {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx; /* h-[1px] → 2rpx */
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.5), transparent);
}
/* Reference: text-4xl font-black text-white/90 drop-shadow-xl */
.pillar-rank {
  font-size: 72rpx;   /* text-4xl → 72rpx */
  font-weight: 900;    /* font-black → 900 */
  color: rgba(255, 255, 255, 0.9); /* text-white/90 */
  filter: drop-shadow(0 40rpx 50rpx rgba(0, 0, 0, 0.25)); /* drop-shadow-xl */
  position: relative;
  z-index: 10;
}

/* ─── Leaderboard Cards ─── */
/* Reference: flex flex-col gap-4 mt-0 relative z-10 */
.cards-section {
  padding: 0; /* no extra padding, parent content-wrapper handles px-4 */
  display: flex;
  flex-direction: column;
  gap: 16rpx; /* gap-4 → 16rpx */
  position: relative;
  z-index: 10;
}

/* Reference: rounded-2xl cursor-pointer group relative overflow-hidden border border-white/10 shadow-lg bg-[#242426] */
.lb-card {
  border-radius: 32rpx; /* rounded-2xl → 32rpx */
  overflow: hidden;
  position: relative;
  background: #1E252E;
  border: 2rpx solid rgba(255, 255, 255, 0.1); /* border-white/10 */
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25); /* shadow-lg */
  opacity: 0;
}

/* Card Background Gradient */
/* Reference: absolute top-0 left-0 w-full h-[140px] z-0 overflow-hidden */
.lb-card-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 280rpx; /* h-[140px] → 280rpx */
  overflow: hidden;
  z-index: 0;
}
.lb-card-bg-gradient {
  width: 100%;
  height: 100%;
  opacity: 0.30;
}
/* Reference: absolute inset-0 bg-gradient-to-b from-transparent via-[#242426]/60 to-[#242426] */
.lb-card-bg-fade {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(30, 37, 46, 0.60) 50%, #1E252E 100%);
}

/* Cover Image */
.lb-card-cover {
  position: absolute;
  top: 0;
  right: 0;
  width: 280rpx;
  height: 100%;
  z-index: 0;
  opacity: 0.45;
  -webkit-mask-image: linear-gradient(to right, transparent 10%, rgba(0,0,0,0.7) 100%);
  mask-image: linear-gradient(to right, transparent 10%, rgba(0,0,0,0.7) 100%);
  border-radius: 0 16rpx 16rpx 0;
}

/* Card Content */
/* Reference: relative z-10 p-4 flex flex-col gap-3 */
.lb-card-content {
  position: relative;
  z-index: 1;
  padding: 16rpx; /* p-4 → 16rpx */
  display: flex;
  flex-direction: column;
  gap: 12rpx; /* gap-3 → 12rpx */
}

/* Header */
/* Reference: flex items-start gap-3 mb-1 pt-12 */
.lb-header {
  gap: 12rpx;        /* gap-3 → 12rpx */
  margin-bottom: 4rpx; /* mb-1 → 4rpx */
  padding-top: 48rpx;  /* pt-12 → 48rpx */
}

/* Rank Badge — Pennant (Top 3) */
/* Reference: relative flex items-center justify-center w-10 h-11 shrink-0 */
.rank-badge-pennant {
  position: relative;
  width: 80rpx;  /* w-10 → 80rpx */
  height: 88rpx; /* h-11 → 88rpx */
  flex-shrink: 0;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 8rpx;
}
.rank-badge-pennant.badge-gold {
  background: linear-gradient(180deg, #FFD666 0%, #FFB800 50%, #CC9300 100%);
  filter: drop-shadow(0 8rpx 12rpx rgba(255, 184, 0, 0.3));
}
.rank-badge-pennant.badge-silver {
  background: linear-gradient(180deg, #E6EDF3 0%, #8B949E 50%, #484F58 100%);
  filter: drop-shadow(0 8rpx 12rpx rgba(139, 148, 158, 0.3));
}
.rank-badge-pennant.badge-bronze {
  background: linear-gradient(180deg, #F0D87E 0%, #D29922 50%, #8B6914 100%);
  filter: drop-shadow(0 8rpx 12rpx rgba(210, 153, 34, 0.3));
}
/* Reference: text-[8px] font-black uppercase tracking-widest, color from colors.text, opacity 0.8 */
.pennant-top {
  font-size: 16rpx;    /* text-[8px] → 16rpx */
  font-weight: 900;     /* font-black → 900 */
  letter-spacing: 4rpx; /* tracking-widest → 4rpx */
  text-transform: uppercase;
  line-height: 1.2;
  opacity: 0.8;
  color: #78350f;
}
/* Reference: text-lg font-black leading-none, color from colors.text */
.pennant-num {
  font-size: 36rpx; /* text-lg → 36rpx */
  font-weight: 900;  /* font-black → 900 */
  color: #78350f;
  line-height: 1; /* leading-none → 1 */
}
/* Silver text color override */
.badge-silver .pennant-top {
  color: #18181b;
}
.badge-silver .pennant-num {
  color: #18181b;
}
/* Bronze text color override */
.badge-bronze .pennant-top {
  color: #431407;
}
.badge-bronze .pennant-num {
  color: #431407;
}

/* Rank Badge — Simple (4+) */
/* Reference: w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-zinc-400 font-bold text-sm border border-white/10 shrink-0 */
.rank-badge-simple {
  width: 64rpx;  /* w-8 → 64rpx */
  height: 64rpx; /* h-8 → 64rpx */
  border-radius: 16rpx; /* rounded-lg → 16rpx */
  background: rgba(255, 255, 255, 0.05); /* bg-white/5 */
  border: 2rpx solid rgba(255, 255, 255, 0.1); /* border-white/10 */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rank-badge-simple-num {
  font-size: 28rpx; /* text-sm → 28rpx */
  font-weight: 700;  /* font-bold → 700 */
  color: #8B949E;    /* text-zinc-400 */
}

/* Title Area */
/* Reference: flex-1 min-w-0 pt-0.5 */
.lb-title-area {
  padding-top: 2rpx; /* pt-0.5 → 2rpx */
}
/* Reference: text-lg font-bold text-white truncate leading-tight drop-shadow-md */
.lb-title {
  font-size: 36rpx; /* text-lg → 36rpx */
  font-weight: 700;  /* font-bold → 700 */
  color: #FFFFFF;
  line-height: 1.25; /* leading-tight → 1.25 */
  filter: drop-shadow(0 8rpx 12rpx rgba(0, 0, 0, 0.25)); /* drop-shadow-md */
}
/* Reference: text-sm text-zinc-300 truncate mt-1 drop-shadow-md */
.lb-author {
  font-size: 28rpx; /* text-sm → 28rpx */
  color: #E6EDF3;    /* text-zinc-300 */
  margin-top: 4rpx;  /* mt-1 → 4rpx */
  filter: drop-shadow(0 8rpx 12rpx rgba(0, 0, 0, 0.25)); /* drop-shadow-md */
}

/* Stats Row */
/* Reference: flex items-center gap-4 */
.lb-stats {
  gap: 16rpx; /* gap-4 → 16rpx */
}

/* CircularProgress */
/* Reference: flex items-center gap-2 */
.progress-wrap {
  gap: 8rpx; /* gap-2 → 8rpx */
}
/* Reference: relative w-8 h-8 flex items-center justify-center */
.approval-badge {
  width: 64rpx;  /* w-8 → 64rpx */
  height: 64rpx; /* h-8 → 64rpx */
  border-radius: 50%;
  border: 5rpx solid; /* strokeWidth 2.5 → ~5rpx */
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}
/* Reference: text-[10px] font-bold */
.approval-num {
  font-size: 20rpx; /* text-[10px] → 20rpx */
  font-weight: 700;  /* font-bold → 700 */
  line-height: 1;
}
/* Reference: text-[10px] text-zinc-400 font-medium */
.progress-label {
  font-size: 20rpx; /* text-[10px] → 20rpx */
  color: #8B949E;    /* text-zinc-400 */
  font-weight: 500;  /* font-medium → 500 */
}

/* Reference: flex flex-col gap-1 */
.stats-info {
  gap: 4rpx; /* gap-1 → 4rpx */
}
/* Reference: flex items-center gap-1.5 */
.stat-line {
  gap: 6rpx; /* gap-1.5 → 6rpx */
}
/* Reference: w-3.5 h-3.5 text-orange-500 (flame icon → emoji) */
.stat-icon-fire {
  font-size: 22rpx;
  color: #FFB800; /* amber accent */
}
/* Reference: text-xs font-medium text-zinc-300 */
.stat-text-light {
  font-size: 24rpx; /* text-xs → 24rpx */
  font-weight: 500;  /* font-medium → 500 */
  color: #E6EDF3;    /* text-zinc-300 */
}
/* Reference: w-3.5 h-3.5 text-blue-400 (play icon) */
.stat-icon-play {
  font-size: 18rpx;
  color: #00A896; /* emerald accent */
}
/* Reference: text-xs text-zinc-400 */
.stat-text-dim {
  font-size: 24rpx; /* text-xs → 24rpx */
  color: #8B949E;    /* text-zinc-400 */
}

/* Tags */
/* Reference: ml-auto flex gap-1.5 self-end */
.lb-tags {
  margin-left: auto;
  gap: 6rpx; /* gap-1.5 → 6rpx */
  align-self: flex-end;
}
/* Reference: px-2 py-1 rounded bg-white/10 backdrop-blur-md text-[10px] font-medium text-white/90 border border-white/10 */
.lb-tag {
  padding: 4rpx 8rpx; /* py-1 px-2 → 4rpx 8rpx */
  border-radius: 8rpx; /* rounded → 8rpx */
  font-size: 20rpx;    /* text-[10px] → 20rpx */
  font-weight: 500;     /* font-medium → 500 */
  color: rgba(255, 255, 255, 0.9); /* text-white/90 */
  background: rgba(255, 255, 255, 0.1); /* bg-white/10 */
  -webkit-backdrop-filter: blur(24rpx); /* backdrop-blur-md */
  backdrop-filter: blur(24rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.1); /* border-white/10 */
}

/* Description Quote */
/* Reference: bg-black/20 rounded-xl p-3 relative border border-white/5 mt-1 */
.lb-quote {
  position: relative;
  background: rgba(0, 0, 0, 0.2); /* bg-black/20 */
  border-radius: 24rpx; /* rounded-xl → 24rpx */
  padding: 12rpx; /* p-3 → 12rpx */
  border: 2rpx solid rgba(255, 255, 255, 0.05); /* border-white/5 */
  margin-top: 4rpx; /* mt-1 → 4rpx */
}
/* Reference: absolute top-2.5 left-2.5 text-zinc-500 font-serif text-2xl leading-none */
.quote-mark {
  font-size: 48rpx; /* text-2xl → 48rpx */
  color: #484F58;    /* text-zinc-500 */
  font-family: serif;
  line-height: 1; /* leading-none → 1 */
}
.quote-open {
  position: absolute;
  top: 10rpx;  /* top-2.5 → 10rpx */
  left: 10rpx; /* left-2.5 → 10rpx */
}
/* Reference: absolute bottom-1 right-2.5 text-zinc-500 font-serif text-2xl leading-none rotate-180 */
.quote-close {
  position: absolute;
  bottom: 4rpx;  /* bottom-1 → 4rpx */
  right: 10rpx;   /* right-2.5 → 10rpx */
  transform: rotate(180deg);
}
/* Reference: text-xs text-zinc-300 pl-5 pr-2 line-clamp-2 leading-relaxed */
.quote-text {
  font-size: 24rpx; /* text-xs → 24rpx */
  color: #E6EDF3;    /* text-zinc-300 */
  padding-left: 20rpx; /* pl-5 → 20rpx */
  padding-right: 8rpx; /* pr-2 → 8rpx */
  line-height: 1.625;  /* leading-relaxed → 1.625 */
}

/* ─── Load More ─── */
.load-more-area {
  padding: 48rpx 0;
}
.pulse-dots {
  gap: 16rpx;
}
.pulse-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-accent);
  opacity: 0.4;
  animation: pulse 1.4s infinite ease-in-out;
}
.pulse-dot:nth-child(2) { animation-delay: 0.2s; }
.pulse-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40% { transform: scale(1); opacity: 0.8; }
}

.end-line {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 20rpx;
}
.end-divider {
  width: 60rpx;
  height: 2rpx;
  background: var(--color-border-strong);
  border-radius: 1rpx;
}
.end-text {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  font-weight: 500;
}

/* ─── Animations ─── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.animate-in {
  animation: fadeInUp 0.5s ease-out forwards;
}
.hero-banner {
  animation: scaleIn 0.5s ease-out forwards;
}

/* ==========================================
   Immersive Cover Cards
   ========================================== */
.cover-card {
  margin: 0 24rpx 36rpx;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  width: calc(100% - 48rpx);
  aspect-ratio: 16 / 9;
  background: #1E252E;
}

.cover-card-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}

.cover-card-placeholder {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1E252E, #262D37);
}

.cover-card-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 65%;
  background: linear-gradient(to top, rgba(10,15,20,0.92) 0%, rgba(10,15,20,0.5) 50%, transparent 100%);
  z-index: 1;
}

/* Rank badge — top left */
.cover-rank {
  position: absolute;
  top: 20rpx; left: 24rpx;
  z-index: 3;
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
.cover-rank-1 { background: #FFB800; }
.cover-rank-2 { background: #8B949E; }
.cover-rank-3 { background: #D29922; }
.cover-rank-n { background: rgba(240,246,252,0.1); }
.cover-rank-num {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}
.cover-rank-1 .cover-rank-num { color: #0A0F14; }
.cover-rank-2 .cover-rank-num { color: #0A0F14; }
.cover-rank-3 .cover-rank-num { color: #0A0F14; }
.cover-rank-n .cover-rank-num { color: #8B949E; }

/* Duration — top right */
.cover-dur {
  position: absolute;
  top: 20rpx; right: 24rpx;
  z-index: 3;
  background: rgba(10,15,20,0.6);
  backdrop-filter: blur(8rpx);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}
.cover-dur-text {
  font-size: 22rpx;
  color: rgba(240,246,252,0.85);
  font-weight: 500;
}

/* Play button — bottom right */
.cover-play {
  position: absolute;
  bottom: 28rpx; right: 28rpx;
  z-index: 3;
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(0,168,150,0.85);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(0,168,150,0.4);
}
.cover-play-tri {
  width: 0; height: 0;
  border-style: solid;
  border-width: 14rpx 0 14rpx 22rpx;
  border-color: transparent transparent transparent #fff;
  margin-left: 4rpx;
}

/* Title + Author — bottom left */
.cover-text {
  position: absolute;
  bottom: 28rpx; left: 28rpx;
  right: 120rpx;
  z-index: 2;
}
.cover-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #F0F6FC;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}
.cover-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 6rpx;
}
.cover-author {
  font-size: 22rpx;
  color: rgba(240,246,252,0.7);
}
.cover-dot {
  width: 6rpx; height: 6rpx;
  border-radius: 50%;
  background: rgba(240,246,252,0.3);
}
.cover-views {
  font-size: 22rpx;
  color: rgba(240,246,252,0.45);
}
.cover-plat {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: rgba(0,168,150,0.2);
  color: #00C9B0;
  font-weight: 600;
}

/* Hero banner cover image */
.hero-banner-cover {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* Hero play triangle (replaces Lucide icon) */
.hero-play-tri {
  width: 0; height: 0;
  border-style: solid;
  border-width: 12rpx 0 12rpx 20rpx;
  border-color: transparent transparent transparent #fff;
  margin-left: 4rpx;
}

/* Nav icon text (replaces Lucide) */
.nav-icon-text {
  font-size: 32rpx;
  color: #8B949E;
}

/* Podium crown text (replaces Lucide) */
.podium-crown-text {
  font-size: 36rpx;
  color: #FFB800;
  margin-bottom: 4rpx;
}

/* Tab bar icon text */
.tab-bar-icon-text {
  font-size: 36rpx;
  line-height: 1;
}

/* Podium avatar as cover thumbnail */
.podium-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
